{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Clipboard Workbench",
  "version": "0.1.0",
  "identifier": "com.clipboard-workbench.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Clipboard Workbench",
        "width": 820,
        "height": 600,
        "minWidth": 720,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
