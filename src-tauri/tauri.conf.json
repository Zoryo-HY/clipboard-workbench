{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Clipboard Workbench",
  "version": "0.1.0",
  "identifier": "com.clipboard-workbench.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "visible": true,
        "width": 800,
        "height": 600,
        "center": true
      },
      {
        "label": "mini",
        "url": "mini.html",
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "visible": false,
        "width": 300,
        "height": 480,
        "minWidth": 260,
        "minHeight": 300,
        "center": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
